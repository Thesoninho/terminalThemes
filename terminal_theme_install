#!/bin/bash

set -e

echo "✞ Instalando Terminal Themes..."

INSTALL_DIR="$HOME/.terminalThemes"

# ================================
# ✞ Criar diretório ⤸
# ================================
echo "➤ Criando diretório em $INSTALL_DIR"
mkdir -p "$INSTALL_DIR"

# ================================
# ✞ Instalar dependência (fzf) ⤸
# ================================
if ! command -v fzf >/dev/null 2>&1; then
    echo "➤ Instalando fzf..."

    if command -v apt >/dev/null 2>&1; then
        sudo apt update
        sudo apt install -y fzf
    else
        echo "✖ Gerenciador de pacotes não suportado. Instale o fzf manualmente."
        exit 1
    fi
else
    echo "✔ fzf já instalado"
fi

# ================================
# ✞ Copiar arquivos ⤸
# ================================
echo "➤ Copiando arquivos..."
cp -r backgrounds "$INSTALL_DIR/"
cp -r PS1s "$INSTALL_DIR/"
cp terminal_get_theme "$INSTALL_DIR/"
cp terminal_theme_bot "$INSTALL_DIR/"
cp terminal_theme_functions "$INSTALL_DIR/"

# ================================
# ✞ Permissões ⤸
# ================================
echo "➤ Ajustando permissões..."
chmod +x "$INSTALL_DIR/terminal_theme_bot"
chmod +x "$INSTALL_DIR/terminal_get_theme"

# ================================
# ✞ Configurar .bashrc ⤸
# ================================
BASHRC="$HOME/.bashrc"

if ! grep -q "^# ✞ CONFIGURATION TO ENABLE TERMINALTHEMES IN YOUR TERMINAL obs: (do not delete)$" "$BASHRC"; then
    printf "\033[38;5;57m➤ Configurando .bashrc...\033[0m\n"

    cat <<EOF >> "$BASHRC"

# =========================================================
# ✞ CONFIGURATION TO ENABLE TERMINALTHEMES IN YOUR TERMINAL obs: (do not delete)
# =========================================================

if [ -f "\$HOME/.terminalThemes/.my_last_theme" ]; then
    source "\$HOME/.terminalThemes/terminal_get_theme"
fi
theme(){
    source "\$HOME/.terminalThemes/terminal_theme_bot"
}

EOF
else
    printf "\033[38;5;213m✔ .bashrc já configurado\033[0m\n"
fi

# ================================
# ✞ Finalização ⤸
# ================================
echo ""
echo "✔ Instalação concluída!"
echo "➤ Reinicie o terminal ou rode:"
echo "   source ~/.bashrc"
echo ""
echo "➤ Depois use o comando:"
echo "   theme"
echo ""